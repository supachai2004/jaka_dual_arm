<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="jaka_dual_arm">

  <link name="world"/>

  <!-- ===== LEFT ARM ===== -->
  <link name="left_base_link"/>
  <joint name="world_to_left_base" type="fixed">
    <parent link="world"/>
    <child link="left_base_link"/>
    <origin xyz="0 0.18 1.16" rpy="1.5708 0 0"/>
  </joint>

  <link name="left_J1">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://jaka_description/meshes/jaka_a12_meshes/J1.STL"/></geometry>
      <material name="lg"><color rgba="0.6 0.8 0.6 1"/></material>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://jaka_description/meshes/jaka_a12_meshes/J1.STL"/></geometry>
    </collision>
    <inertial><mass value="5.0"/><origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
  </link>
  <joint name="left_joint_1" type="revolute">
    <parent link="left_base_link"/><child link="left_J1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-6.28" upper="6.28" effort="8000" velocity="1.92"/>
  </joint>

  <link name="left_J2">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://jaka_description/meshes/jaka_a12_meshes/J2.STL"/></geometry>
      <material name="lg"><color rgba="0.6 0.8 0.6 1"/></material>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://jaka_description/meshes/jaka_a12_meshes/J2.STL"/></geometry>
    </collision>
    <inertial><mass value="13.37"/><origin xyz="0.32342 0 0.1801" rpy="0 0 0"/>
      <inertia ixx="0.038258" ixy="0" ixz="-0.0030725" iyy="1.0882" iyz="0" izz="1.0803"/>
    </inertial>
  </link>
  <joint name="left_joint_2" type="revolute">
    <parent link="left_J1"/><child link="left_J2"/>
    <origin xyz="0 0 0" rpy="1.5708 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-6.28" upper="6.28" effort="8000" velocity="2.62"/>
  </joint>

  <link name="left_J3">
