    <inertial><mass value="1.9435"/><origin xyz="0 -0.0024273 0.002914" rpy="0 0 0"/>
      <inertia ixx="0.0057394" ixy="0" ixz="0" iyy="0.0038913" iyz="0" izz="0.0056521"/>
